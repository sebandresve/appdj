{
  "name": "dj-profiles-app",
  "version": "1.0.0",
  "description": "Sistema de administración de perfiles de DJs",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "start": "npm run dev"
  },
  "keywords": ["dj", "profile", "crud", "react", "express", "mongodb"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
